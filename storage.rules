rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Authenticated users can only read and write their own ePub files.
    match /users/{uid}/files/{bookId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Authenticated users can only read and write their own cover images.
    match /users/{uid}/covers/{bookId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
